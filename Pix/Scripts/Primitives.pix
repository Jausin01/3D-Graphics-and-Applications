SetResolution(30,30,20,true)

BeginDraw(point)
Vertex(2,2, 1,0,0)
Vertex(3,3, 0,1,0)
Vertex(7,7, 0,0,1)

EndDraw()

BeginDraw(line)
Vertex(8,8,1,1,0)
Vertex(10,10,0,1,1)
Vertex(0,0,0,0,0)
Vertex(0,29,1,1,1)
Vertex(1,0,0,0,0)
Vertex(1,29,1,0,0)

EndDraw()

BeginDraw(triangle)
SetFillMode(solid)
Vertex(29,0,1,0,1)
Vertex(14,14,0,1,0)
Vertex(29,29,0,0,1)

EndDraw()

BeginDraw(triangle)
SetFillMode(wireframe)
Vertex(0,0,1,0,1)
Vertex(14,14,0,1,0)
Vertex(0,29,14,0,0,1)

EndDraw()



